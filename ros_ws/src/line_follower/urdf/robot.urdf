<?xml version="1.0"?>

<robot name="line_robot">

  <!-- ================= BASE ================= -->

  <link name="base_link">

    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <box size="0.20 0.15 0.05"/>
      </geometry>

      <material name="Blue">
        <color rgba="0 0.3 1 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <box size="0.20 0.15 0.05"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.05"/>
      <mass value="1.0"/>

      <inertia
        ixx="0.01"
        ixy="0"
        ixz="0"
        iyy="0.01"
        iyz="0"
        izz="0.01"/>
    </inertial>

  </link>

  <!-- ================= LEFT WHEEL ================= -->

  <link name="left_wheel">

    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>

      <geometry>
        <cylinder radius="0.03" length="0.02"/>
      </geometry>

      <material name="Black">
        <color rgba="0 0 0 1"/>
      </material>

    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>

      <geometry>
        <cylinder radius="0.03" length="0.02"/>
      </geometry>
    </collision>

    <inertial>

      <mass value="0.2"/>

      <inertia
        ixx="0.001"
        ixy="0"
        ixz="0"
        iyy="0.001"
        iyz="0"
        izz="0.001"/>
    </inertial>

  </link>

  <!-- ================= RIGHT WHEEL ================= -->

  <link name="right_wheel">

    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>

      <geometry>
        <cylinder radius="0.03" length="0.02"/>
      </geometry>

      <material name="Black">
        <color rgba="0 0 0 1"/>
      </material>

    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>

      <geometry>
        <cylinder radius="0.03" length="0.02"/>
      </geometry>
    </collision>

    <inertial>

      <mass value="0.2"/>

      <inertia
        ixx="0.001"
        ixy="0"
        ixz="0"
        iyy="0.001"
        iyz="0"
        izz="0.001"/>
    </inertial>

  </link>

  <!-- ================= JOINTS ================= -->

  <joint name="left_wheel_joint" type="continuous">

    <parent link="base_link"/>
    <child link="left_wheel"/>

    <origin xyz="0 0.08 0.03"/>

    <axis xyz="0 1 0"/>

  </joint>

  <joint name="right_wheel_joint" type="continuous">

    <parent link="base_link"/>
    <child link="right_wheel"/>

    <origin xyz="0 -0.08 0.03"/>

    <axis xyz="0 1 0"/>

  </joint>

  <!-- ================= IR SENSOR LINKS ================= -->

  <link name="ir_left"/>
  <link name="ir_center"/>
  <link name="ir_right"/>

  <joint name="ir_left_joint" type="fixed">

    <parent link="base_link"/>
    <child link="ir_left"/>

    <origin xyz="0.08 0.03 0.01"/>

  </joint>

  <joint name="ir_center_joint" type="fixed">

    <parent link="base_link"/>
    <child link="ir_center"/>

    <origin xyz="0.08 0.0 0.01"/>

  </joint>

  <joint name="ir_right_joint" type="fixed">

    <parent link="base_link"/>
    <child link="ir_right"/>

    <origin xyz="0.08 -0.03 0.01"/>

  </joint>

  <!-- ================= DIFF DRIVE ================= -->

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">

      <ros>

        <namespace>/</namespace>

        <remapping>
          cmd_vel:=/cmd_vel
        </remapping>

        <remapping>
          odom:=/odom
        </remapping>

      </ros>

      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.16</wheel_separation>
      <wheel_diameter>0.06</wheel_diameter>

      <max_wheel_torque>20</max_wheel_torque>

      <publish_odom>true</publish_odom>

      <publish_odom_tf>true</publish_odom_tf>

      <odometry_frame>odom</odometry_frame>

      <robot_base_frame>base_link</robot_base_frame>

      <update_rate>50</update_rate>

    </plugin>
  </gazebo>

</robot>

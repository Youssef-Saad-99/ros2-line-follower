  <build_depend>ros2launch</build_depend>

  <!-- ======================================================================
       EXECUTION (RUNTIME) DEPENDENCIES
       Packages that must be present when nodes are launched.
       ====================================================================== -->

  <!-- Core ROS 2 Python client library -->
  <exec_depend>rclpy</exec_depend>

  <!-- Standard message types used by all nodes -->
  <exec_depend>std_msgs</exec_depend>

  <!-- geometry_msgs/Twist — published by line_controller_node on /cmd_vel -->
  <exec_depend>geometry_msgs</exec_depend>

  <!-- nav_msgs/Odometry — published by encoder_odometry_node on /odom -->
  <exec_depend>nav_msgs</exec_depend>

  <!-- sensor_msgs — reserved for future IMU or camera integration -->
  <exec_depend>sensor_msgs</exec_depend>

  <!-- TF2 — encoder_odometry_node broadcasts odom → base_link transform -->
  <exec_depend>tf2</exec_depend>
  <exec_depend>tf2_ros</exec_depend>
  <exec_depend>tf2_geometry_msgs</exec_depend>

  <!-- Launch system — required for line_follow.launch.py -->
  <exec_depend>ros2launch</exec_depend>
  <exec_depend>launch</exec_depend>
  <exec_depend>launch_ros</exec_depend>

  <!-- cv_bridge / image_transport — reserved for future camera-based detection -->
  <exec_depend>cv_bridge</exec_depend>
  <exec_depend>image_transport</exec_depend>

  <!-- ======================================================================
       TEST DEPENDENCIES
       Packages required only when running colcon test.
       ====================================================================== -->

  <test_depend>ament_copyright</test_depend>
  <test_depend>ament_flake8</test_depend>
  <test_depend>ament_pep257</test_depend>
  <test_depend>python3-pytest</test_depend>

  <!-- ======================================================================
